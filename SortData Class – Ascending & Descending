import java.util.Scanner; import java.util.Arrays;
class SortData {
  void ascending(int[] arr) { Arrays.sort(arr); }
  void descending(int[] arr) {
    Arrays.sort(arr);
    for (int i = 0, j = arr.length-1; i < j; i++, j--) { int t = arr[i]; arr[i] = arr[j]; arr[j] = t; }
  }
  void printArray(int[] arr) { for (int n : arr) System.out.print(n + " "); System.out.println(); }
}
public class Main {
  public static void main(String[] args) {
    Scanner sc = new Scanner(System.in);
    SortData s = new SortData();
    System.out.print("Enter number of elements: ");
    int[] data = new int[sc.nextInt()];
    System.out.println("Enter " + data.length + " elements:");
    for (int i = 0; i < data.length; i++) data[i] = sc.nextInt();
    s.ascending(data);  System.out.print("Ascending Order: ");  s.printArray(data);
    s.descending(data); System.out.print("Descending Order: "); s.printArray(data);
    sc.close();
  }
}
