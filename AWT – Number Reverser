import java.awt.*; import java.awt.event.*;
public class ReverseAWT extends Frame implements ActionListener {
  TextField t = new TextField(10);
  Button b = new Button("Reverse");
  Label res = new Label("Result will appear here");
  public ReverseAWT() {
    setLayout(new FlowLayout());
    add(new Label("Enter Number:")); add(t); add(b); add(res);
    b.addActionListener(this);
    setTitle("Number Reverser"); setSize(350, 150); setVisible(true);
  }
  public void actionPerformed(ActionEvent e) {
    try { int n = Integer.parseInt(t.getText()), rev = 0; while (n!=0) { rev = rev*10 + n%10; n/=10; } res.setText("Reversed Number: "+rev); }
    catch (Exception ex) { res.setText("Invalid input!"); }
  }
  public static void main(String[] args) { new ReverseAWT(); }
}
