import java.awt.*; import java.awt.event.*;
public class FactorialAWT extends Frame implements ActionListener {
  TextField t = new TextField(10);
  Button b = new Button("Calculate");
  Label res = new Label("Result will appear here");
  public FactorialAWT() {
    setLayout(new FlowLayout());
    add(new Label("Enter Number:")); add(t); add(b); add(res);
    b.addActionListener(this);
    setTitle("Factorial Finder"); setSize(350, 150); setVisible(true);
  }
  public void actionPerformed(ActionEvent e) {
    try { int n = Integer.parseInt(t.getText()); long f = 1; for (int i=1; i<=n; i++) f*=i; res.setText("Factorial is: "+f); }
    catch (Exception ex) { res.setText("Please enter a valid number!"); }
  }
  public static void main(String[] args) { new FactorialAWT(); }
}
