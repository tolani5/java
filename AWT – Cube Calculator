import java.awt.*; import java.awt.event.*;
public class CubeAWT extends Frame implements ActionListener {
  TextField t = new TextField(10);
  Button b = new Button("Find Cube");
  Label res = new Label("Result will appear here");
  public CubeAWT() {
    setLayout(new FlowLayout());
    add(new Label("Enter Number:")); add(t); add(b); add(res);
    b.addActionListener(this);
    setTitle("Cube Calculator"); setSize(350, 150); setVisible(true);
  }
  public void actionPerformed(ActionEvent e) {
    try { int n = Integer.parseInt(t.getText()); res.setText("Cube of "+n+" is: "+(n*n*n)); }
    catch (Exception ex) { res.setText("Invalid input!"); }
  }
  public static void main(String[] args) { new CubeAWT(); }
}
